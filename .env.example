# MultiCoder — environment variable defaults
# Copy to .env and customise before running docker compose up.

# UI port exposed on the host (default 8050)
UI_HOST_PORT=8050

# UI port the supervisor listens on inside the container (default 8050)
UI_CONTAINER_PORT=8050

# Icecast port exposed on the host
ICECAST_PORT=8000

# Number of encoders to activate (1-5)
ENCODER_COUNT=5

# Icecast credentials
ICECAST_SOURCE_PASSWORD=hackme
ICECAST_ADMIN_PASSWORD=secureadmin
ICECAST_RELAY_PASSWORD=relaypass
ICECAST_HOSTNAME=localhost
